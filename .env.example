# ===================================================================
# UltraPilot Dashboard - Environment Variables Configuration
# ===================================================================
# IMPORTANT: Copy this file to .env.local and NEVER commit .env.local
# .env.example is safe to commit as it contains only example values
# ===================================================================

# -------------------------------------------------------------------------------
# GitHub App Configuration (RECOMMENDED - Server-side only)
# -------------------------------------------------------------------------------
# GitHub App ID (found in app settings)
GITHUB_APP_ID=your_app_id_here

# GitHub App Installation ID (found in app settings)
GITHUB_APP_INSTALLATION_ID=your_installation_id_here

# Path to GitHub App private key file
# Download from app settings and store securely
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Repository owner (username or organization)
GITHUB_OWNER=your_username

# Repository name
GITHUB_REPO=your_repository

# -------------------------------------------------------------------------------
# Alternative: GitHub Personal Access Token (NOT RECOMMENDED)
# -------------------------------------------------------------------------------
# Only use this for development. Use GitHub App for production.
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# GITHUB_TOKEN=your_token_here

# -------------------------------------------------------------------------------
# Application Configuration
# -------------------------------------------------------------------------------
# Site URL (public - will be exposed to frontend)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Application Name (public)
NEXT_PUBLIC_APP_NAME=UltraPilot Dashboard

# -------------------------------------------------------------------------------
# Optional Configuration
# -------------------------------------------------------------------------------
# GitHub API Base URL (for GitHub Enterprise Server)
# Default: https://api.github.com
# GITHUB_API_URL=https://api.github.com

# WebSocket URL for real-time updates (development only)
# WS_URL=ws://localhost:3001

# Session Secret for authentication (generate a random string)
# Use: openssl rand -base64 32
# SESSION_SECRET=your-random-session-secret-here

# -------------------------------------------------------------------------------
# Security Notes
# -------------------------------------------------------------------------------
# 1. NEVER commit .env.local to git (it's in .gitignore)
# 2. NEVER use NEXT_PUBLIC_ prefix for sensitive data (tokens, secrets)
# 3. Only NEXT_PUBLIC_ vars are exposed to the browser
# 4. Rotate credentials regularly
# 5. Use GitHub App authentication in production (not personal tokens)
# 6. Keep private keys secure and never expose them to frontend
# -------------------------------------------------------------------------------
